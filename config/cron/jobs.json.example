{
  "version": 1,
  "jobs": [
    {
      "id": "00000000-0000-0000-0000-000000000001",
      "name": "generate-drafts",
      "description": "콘텐츠 배치 생성 (6시간마다)",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "everyMs": 21600000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "다음을 수행하라:\n1. 스타일 데이터와 인기글 패턴을 확인\n2. prompt-guide.txt를 읽어 콘텐츠 가이드 확인\n3. 가이드에 따라 글 5개를 생성하여 draft로 저장\n4. 실패한 글은 건너뛰고 최소 3개 이상 생성"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      }
    },
    {
      "id": "00000000-0000-0000-0000-000000000002",
      "name": "multi-channel-publish",
      "description": "승인된 글 멀티채널 발행 (2시간마다)",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "everyMs": 7200000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "승인된 글을 확인하고, 활성화된 각 채널로 발행하라. 채널별 성공/실패를 기록하고, 완료 후 오래된 글을 정리하라.",
        "model": "anthropic/claude-haiku-4-5"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      }
    },
    {
      "id": "00000000-0000-0000-0000-000000000003",
      "name": "collect-insights",
      "description": "발행된 글 반응 수집 + 바이럴 감지 (6시간마다)",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "everyMs": 21600000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "발행된 글의 반응(views/likes/replies/reposts)을 수집하고, 바이럴 글을 자동 감지하여 인기글 데이터에 반영하라.",
        "model": "anthropic/claude-haiku-4-5"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      }
    },
    {
      "id": "00000000-0000-0000-0000-000000000004",
      "name": "fetch-trending",
      "description": "외부 인기글 수집 (주 1회)",
      "enabled": false,
      "schedule": {
        "kind": "every",
        "everyMs": 604800000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "search-keywords.txt의 키워드로 인기글을 검색하고 popular-posts.txt를 업데이트하라.",
        "model": "anthropic/claude-haiku-4-5"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      }
    },
    {
      "id": "00000000-0000-0000-0000-000000000005",
      "name": "track-growth",
      "description": "팔로워 수/증감 추적 (매일 1회)",
      "enabled": true,
      "schedule": {
        "kind": "every",
        "everyMs": 86400000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "팔로워 수와 프로필 조회수를 수집하고 growth.json을 업데이트하라.",
        "model": "anthropic/claude-haiku-4-5"
      },
      "delivery": {
        "mode": "none",
        "channel": "last"
      }
    }
  ]
}
